# ============================================================
# NEXUS — ENVIRONMENT VARIABLES TEMPLATE
# Copy this to .env and fill in real values.
# .env is in .gitignore — NEVER commit it.
# In Koyeb: add these in the dashboard under Environment Variables.
# ============================================================

# --- LLM API KEYS ---
GROQ_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# --- DATABASE (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- MEMORY ---
# Uses same keys as above — kept separate for clarity
MEM0_COHERE_API_KEY=
GRAPHITI_NEO4J_URI=
GRAPHITI_NEO4J_USER=
GRAPHITI_NEO4J_PASSWORD=

# --- PAYMENTS ---
CDP_API_KEY_NAME=
CDP_API_KEY_SECRET=
X402_NETWORK=base-sepolia
AGENT_WALLET_ADDRESS=

# --- PLATFORMS ---
PINAI_API_KEY=
PINAI_AGENT_ID=
PINAI_API_URL=https://agents.pinai.tech

# --- OBSERVABILITY ---
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexus-prod
LANGCHAIN_TRACING_V2=true

# --- SECURITY ---
LLAMAFIREWALL_ENABLED=true
MAX_SPEND_PER_SESSION_USDC=5.0

# --- SERVER ---
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production
