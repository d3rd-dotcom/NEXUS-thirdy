# ============================================================
# NEXUS-thirdy — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in real values.
# .env is listed in .gitignore — NEVER commit it.
# On Render: paste each key under Environment Variables in the dashboard.
# ============================================================

# --- LLM API KEYS ---
GROQ_API_KEY=
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=

# --- DATABASE (Supabase) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# FIXED (M1): Infrastructure details moved out of source code.
# Find SUPABASE_PROJECT_REF in: Supabase dashboard → Settings → General → Reference ID
# Find SUPABASE_POOLER_HOST in: Supabase dashboard → Settings → Database → Connection pooling
SUPABASE_PROJECT_REF=
SUPABASE_POOLER_HOST=aws-0-ap-southeast-1.pooler.supabase.com

# --- MEMORY ---
GRAPHITI_NEO4J_URI=
GRAPHITI_NEO4J_USER=
GRAPHITI_NEO4J_PASSWORD=

# --- PAYMENTS ---
CDP_API_KEY_NAME=
CDP_API_KEY_SECRET=
X402_NETWORK=base-sepolia
AGENT_WALLET_ADDRESS=

# FIXED (C2): Payment verification toggle.
# false (default) = stub mode: ONLY proofs prefixed with "stub_test_" are accepted.
# true            = full x402 cryptographic verification via Coinbase CDP facilitator.
# Set to true before accepting real USDC payments in production.
X402_VERIFY_PAYMENTS=false

# --- PLATFORMS ---
PINAI_API_KEY=
PINAI_AGENT_ID=
PINAI_API_URL=https://agents.pinai.tech

# FIXED (H6): These were previously missing from .env.example entirely.
FETCHAI_API_KEY=
MINDSTUDIO_WEBHOOK_SECRET=
TOKU_API_KEY=

# --- OBSERVABILITY ---
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexus-thirdy-prod

# FIXED (H8): Changed default from true → false.
# Tracing sends all user messages to LangSmith — a GDPR concern if enabled by default.
# Set to true explicitly only when you need to debug a specific production issue.
LANGCHAIN_TRACING_V2=false

# --- SECURITY ---
LLAMAFIREWALL_ENABLED=true
MAX_SPEND_PER_SESSION_USDC=5.0

# FIXED (H3): Rate limiting — requests per IP per minute. Default 20.
# Increase for trusted high-volume integrations.
RATE_LIMIT_PER_MINUTE=20

# FIXED (H4): CORS allowlist. Leave empty to block all cross-origin requests (safest default).
# For production, add your frontend origins as a comma-separated list:
# ALLOWED_ORIGINS=https://your-app.com,https://app.mindstudio.ai
ALLOWED_ORIGINS=

# --- SERVER ---
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production
